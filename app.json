{
  "expo": {
    "name": "Back to Safety",
    "slug": "back-to-safety",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "backtosafety",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["READ_CONTACTS"],
      "package": "com.backtosafety.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Back to Safety to access your contacts so you can quickly import emergency contacts."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Back to Safety to access your photos so you can choose or update a profile picture for emergency identification.",
          "cameraPermission": "Allow Back to Safety to use your camera to take a profile photo for emergency identification."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
