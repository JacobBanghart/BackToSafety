# PostHog analytics (self-hosted)
EXPO_PUBLIC_POSTHOG_HOST=https://posthog.backtosafety.app
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_project_api_key

# Sentry crash reporting (self-hosted)
# Obtain DSN from your Sentry project client keys.
EXPO_PUBLIC_SENTRY_DSN=https://<public-key>@sentry.backtosafety.app/<project-id>
