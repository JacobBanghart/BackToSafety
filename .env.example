# Sentry crash reporting (self-hosted)
# Obtain DSN from your Sentry project client keys.
EXPO_PUBLIC_SENTRY_DSN=https://<public-key>@sentry.backtosafety.app/<project-id>

# OpenReplay session replay (self-hosted)
# Obtain project key from your OpenReplay project settings.
EXPO_PUBLIC_OPENREPLAY_PROJECT_KEY=
EXPO_PUBLIC_OPENREPLAY_INGEST_POINT=https://openreplay.backtosafety.app/ingest